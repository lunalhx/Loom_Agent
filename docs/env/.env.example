SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8091
TZ=Asia/Shanghai
COMPOSE_PROJECT_NAME=loom-agent

APP_HOST_PORT=8091

DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=2048

AI_CONNECT_TIMEOUT_MS=10000
AI_FIRST_TOKEN_TIMEOUT_MS=30000
AI_STREAM_TIMEOUT_MS=120000
AI_RETRY_MAX_ATTEMPTS=3
AI_RETRY_BACKOFF_INITIAL_MS=300
AI_RETRY_BACKOFF_MAX_MS=3000
AI_MAX_MESSAGE_LENGTH=20000

AGENT_ENABLED=true
AGENT_WORKSPACE_ROOT=.
AGENT_MAX_STEPS=6
AGENT_TOTAL_TIMEOUT_MS=120000
AGENT_STEP_TIMEOUT_MS=30000
AGENT_TOOL_TIMEOUT_MS=3000
AGENT_OBSERVATION_MAX_CHARS=8000
AGENT_PARSE_ERROR_MAX_ATTEMPTS=2
AGENT_FILE_MAX_BYTES=200000
AGENT_SEARCH_MAX_RESULTS=50

MYSQL_HOST=127.0.0.1
MYSQL_PORT=13306
MYSQL_HOST_PORT=13306
MYSQL_DATABASE=loom_agent
MYSQL_USER=root
MYSQL_ROOT_PASSWORD=123456

REDIS_HOST=127.0.0.1
REDIS_PORT=16379
REDIS_HOST_PORT=16379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT_MS=3000

PHPMYADMIN_HOST_PORT=8899
REDIS_ADMIN_HOST_PORT=8081
