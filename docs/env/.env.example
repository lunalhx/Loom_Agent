SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8091
TZ=Asia/Shanghai
COMPOSE_PROJECT_NAME=loom-agent

APP_HOST_PORT=8091
APP_IMAGE=loom-agent-app
APP_VERSION=1.0-SNAPSHOT

DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=2048

AI_CONNECT_TIMEOUT_MS=10000
AI_FIRST_TOKEN_TIMEOUT_MS=30000
AI_STREAM_TIMEOUT_MS=120000
AI_RETRY_MAX_ATTEMPTS=3
AI_RETRY_BACKOFF_INITIAL_MS=300
AI_RETRY_BACKOFF_MAX_MS=3000
AI_MAX_MESSAGE_LENGTH=20000

MCP_ENABLED=false
MCP_REQUEST_TIMEOUT_MS=60000
MCP_MAX_TOOLS_PER_SERVER=64
EXA_MCP_ENABLED=true
PLAYWRIGHT_MCP_ENABLED=true
PLAYWRIGHT_MCP_TRANSPORT=STDIO
PLAYWRIGHT_MCP_COMMAND=npx

AGENT_ENABLED=true
AGENT_WORKSPACE_ROOT=.
AGENT_MAX_STEPS=6
AGENT_TOTAL_TIMEOUT_MS=600000
AGENT_STEP_TIMEOUT_MS=120000
AGENT_TOOL_TIMEOUT_MS=3000
AGENT_MODEL_ESCALATED_MAX_TOKENS=8192
AGENT_OBSERVATION_MAX_CHARS=8000
AGENT_PARSE_ERROR_MAX_ATTEMPTS=2
AGENT_FILE_MAX_BYTES=200000
AGENT_SEARCH_MAX_RESULTS=50
AGENT_HIGH_RISK_POLICY=CONFIRM
AGENT_PERMISSION_MODE=SANDBOX
# AGENT_ALLOWED_SHELL_COMMANDS is deprecated; use AGENT_SHELL_* instead
AGENT_ALLOWED_SHELL_COMMANDS=mvn,./mvnw,git,pwd,ls,rg
AGENT_SHELL_READ_ONLY=pwd,ls,cat,head,tail,wc,grep,sort,uniq,which,file,du,df,echo,rg
AGENT_SHELL_WRITE=mkdir,cp,mv,touch,chmod,date,printf
AGENT_SHELL_HIGH_RISK=curl,wget,npm,yarn,pip,pip3,docker,ssh,scp,rsync,chown,kill,systemctl,sudo,sed,awk,tar,zip,unzip
AGENT_SHELL_DENY=rm,rmdir,find,python,python3,sh,bash,zsh,dash,ksh,csh,fish,ash,exec,eval,source
AGENT_SHELL_UNKNOWN_LEVEL=WRITE_CONFIRM
HOST_WORKSPACE_ROOT=../..
CONTAINER_WORKSPACE_ROOT=/workspace
CONTAINER_WORKSPACE_ROOTS=/workspace

AGENT_PERSISTENCE_MODE=sqlite
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_MAX_POOL_SIZE=4
# LOOM_DATA_DIR=/absolute/path/to/.loom-agent
# AGENT_CONTEXT_STORAGE_ROOT=/absolute/path/to/context-artifacts
